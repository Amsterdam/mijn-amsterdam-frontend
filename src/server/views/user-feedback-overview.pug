h1=feedbackOverview.survey.title

p Totaal aantal inzendingen: #{feedbackOverview.entries.length}
p Gemiddeld cijfer (op deze pagina) #{feedbackOverview.score}

if feedbackOverview.pageLinks.length > 1
  nav
    | Pagina:
    each link in feedbackOverview.pageLinks
      a(href=link.url)
        if link.page === feedbackOverview.currentPage
          strong #{link.page}
        else
          | #{link.page}
      | &nbsp;

table(border='1', cellpadding='5', cellspacing='0')
  thead
    tr
      th ID
      th Datum inzending
      th Entrypoint
      th Pagina titel
      each question, id in feedbackOverview.survey.questions
        th= question
      th Errors
      th Thema's
      th Metadata
  tbody
    each entry in feedbackOverview.entries
      tr
        td
          a(id=`entry-${entry.id}` href=`#entry-${entry.id}`)
            strong #{entry.id}
        td= entry.dateCreatedFormatted
        td= entry.entryPoint
        td= entry.browserTitle
        each question, id in feedbackOverview.survey.questions
          td= entry.answers[id] || '-'
        td
          ul
            each error in entry.maErrors || []
              li #{error.name} - #{error.error}
        td
          ul
            each thema in entry.maThemas || []
              li #{thema}
        td
          pre= JSON.stringify(entry.metadata, null, 2)



